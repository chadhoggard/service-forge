# Database
# Format: postgresql://<user>:<password>@<host>:<port>/<dbname>
DATABASE_URL=postgresql://serviceforge:serviceforge@localhost:5432/serviceforge

# Auth
SECRET_KEY=replace-with-a-long-random-string
SERVICEFORGE_API_KEY=replace-with-a-long-random-api-key

# GitHub Actions integration
# Fine-grained token with: Actions (read/write), Contents (read), Metadata (read)
GITHUB_TOKEN=
# Workflow file in .github/workflows/ of each registered repo
GITHUB_WORKFLOW_FILE=deploy.yml
